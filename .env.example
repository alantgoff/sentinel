# Aegis — copy to .env and fill in. Never commit .env.
# Create a free testnet account at https://portal.hedera.com/dashboard (use ECDSA key).

# --- Buyer (the AI company purchasing the cost cap) ---
BUYER_ACCOUNT_ID=0.0.xxxxxx
BUYER_PRIVATE_KEY=          # ECDSA hex (with or without 0x prefix)

# --- Underwriter (the Aegis pool that collects premiums and pays out) ---
# For the realistic demo create a SECOND testnet account distinct from the buyer.
UNDERWRITER_ACCOUNT_ID=0.0.yyyyyy
UNDERWRITER_PRIVATE_KEY=

# --- (Optional) Mock supply provider (in-kind hook demo) ---
PROVIDER_ACCOUNT_ID=
PROVIDER_PRIVATE_KEY=

# --- Network ---
HEDERA_NETWORK=testnet                                       # testnet | previewnet | mainnet (mainnet disabled in code)
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# --- Aegis HCS topic (Aegis envelopes: POLICY / PRICE_REF / SETTLEMENT / PROVIDER_CAPACITY) ---
# Leave blank on first run; `npm run smoke:hcs` will create one and print the id.
AEGIS_TOPIC_ID=

# --- LLM (optional — the deterministic flow doesn't need it; only the NL-buyer agent does) ---
LLM_PROVIDER=groq                # groq | openai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- Pool / pricing defaults ---
# R0 in USD per GPU-hour (H100 class). Calibrated default ≈ $2.50/hr.
DEFAULT_R0_USD_HR=2.50
# Max aggregate exposure relative to pool balance (e.g., 0.5 = pool can underwrite policies
# whose worst-case combined payout is 50% of the current pool balance).
MAX_EXPOSURE_RATIO=0.5
# Max single payout above which the underwriter switches to RETURN_BYTES human approval.
PAYOUT_AUTONOMOUS_CAP_HBAR=10
