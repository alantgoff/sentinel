# Sentinel — copy to .env and fill in. Never commit .env.
# Create a free testnet account at https://portal.hedera.com/dashboard (use ECDSA key).

# --- Buyer agent (the one extending credit / paying) ---
BUYER_ACCOUNT_ID=0.0.xxxxxx
BUYER_PRIVATE_KEY=          # ECDSA hex (no 0x prefix needed)

# --- Seller agent (the one offering a paid service) ---
# For local demo you can reuse the buyer's account; for the deployed demo create a second testnet account.
SELLER_ACCOUNT_ID=0.0.yyyyyy
SELLER_PRIVATE_KEY=

# --- Network ---
HEDERA_NETWORK=testnet                                       # testnet | previewnet | mainnet (mainnet disabled in code)
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com        # used for independent verification

# --- Sentinel HCS topic ---
# Leave blank on first run; `npm run smoke:hcs` will create one and print the ID to set here.
SENTINEL_TOPIC_ID=

# --- LLM (default: Groq free tier; OpenAI also supported) ---
LLM_PROVIDER=groq                # groq | openai
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# --- Policy defaults (overridable from the UI per-counterparty) ---
DEFAULT_AUTONOMOUS_CAP_HBAR=2
DEFAULT_DAILY_LIMIT_HBAR=20
DEFAULT_VELOCITY_WINDOW_SECONDS=300
DEFAULT_VELOCITY_MAX_TXNS=5
