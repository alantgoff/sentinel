{
  "name": "aegis",
  "version": "0.2.0-pivot",
  "description": "Aegis — autonomous underwriter agent on Hedera selling cost-cap options on H100 GPU-hour rentals. European-style cap, Monte Carlo priced, HBAR settled, mirror-node verified. Hedera AI Agent Bounty Week 5 (Policy Agent).",
  "type": "module",
  "main": "src/server/app.js",
  "scripts": {
    "start": "node src/server/app.js",
    "dev": "node --watch src/server/app.js",
    "smoke:balance": "node scripts/connectivity-smoke.js",
    "smoke:hcs": "node scripts/hcs-roundtrip.js",
    "smoke:lifecycle": "node scripts/lifecycle-smoke.js",
    "verify:tx": "node scripts/verify-tx.js",
    "mcp": "node src/mcp-server.js",
    "test": "node --test --test-reporter=spec test/"
  },
  "keywords": [
    "hedera",
    "hedera-agent-kit",
    "policy-agent",
    "compute-cost",
    "gpu-hours",
    "option-pricing",
    "monte-carlo",
    "jump-diffusion",
    "underwriter",
    "hcs",
    "mirror-node",
    "x402",
    "mcp"
  ],
