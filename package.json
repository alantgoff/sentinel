  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.81.0",
    "@langchain/core": "^1.1.48",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "hedera-agent-kit": "^3.8.2",
    "langchain": "^1.4.2",
    "zod": "^4.4.3"
  }
